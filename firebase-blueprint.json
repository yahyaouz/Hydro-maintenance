{
  "entities": {
    "site": {
      "title": "Site",
      "description": "Un site minier",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "nom": { "type": "string" },
        "code": { "type": "string" }
      },
      "required": ["id", "nom", "code"]
    },
    "engin": {
      "title": "Engin",
      "description": "Un engin de la flotte",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "id_parc": { "type": "string" },
        "modele": { "type": "string" },
        "site": { "type": "string" },
        "status": { "enum": ["EN SERVICE", "PANNE", "MAINTENANCE", "ARRÊT"] },
        "compteur": { "type": "number" },
        "sante": { "type": "number" },
        "disponibilite": { "type": "number" }
      },
      "required": ["id", "id_parc", "modele", "site", "status", "compteur"]
    },
    "panne": {
      "title": "Panne",
      "description": "Signalement d'une panne",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "enginId": { "type": "string" },
        "titre": { "type": "string" },
        "priorite": { "enum": ["CRITIQUE", "ÉLEVÉ", "MOYEN", "BAS"] },
        "status": { "enum": ["OUVERT", "EN COURS", "RÉSOLU"] },
        "site": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "description": { "type": "string" }
      },
      "required": ["id", "enginId", "titre", "priorite", "status", "site", "date"]
    },
    "piece": {
      "title": "Pièce",
      "description": "Pièce détachée en stock",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "ref": { "type": "string" },
        "nom": { "type": "string" },
        "categorie": { "type": "string" },
        "stock": { "type": "number" },
        "min": { "type": "number" },
        "prix": { "type": "number" },
        "siteId": { "type": "string" }
      },
      "required": ["id", "ref", "nom", "stock", "min", "prix", "siteId"]
    },
    "user": {
      "title": "User",
      "description": "Profil utilisateur du système SOU-GMAO",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string" },
        "siteId": { "type": "string" },
        "active": { "type": "boolean" },
        "createdAt": { "type": "string" },
        "lastLogin": { "type": "string" },
        "authProvider": { "type": "string" }
      },
      "required": ["uid", "displayName", "email", "role", "siteId", "active", "authProvider"]
    },
    "lotoLock": {
      "title": "LotoLock",
      "description": "État de consignation LOTO d'un engin ou machine de la flotte",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "machineCode": { "type": "string" },
        "lotoLocked": { "type": "boolean" },
        "lotoOwner": { "type": "string" },
        "lotoStartedAt": { "type": "string" },
        "lotoReleasedAt": { "type": "string" },
        "lotoWorkOrderId": { "type": "string" },
        "lotoSupervisorValidation": { "type": "boolean" },
        "lotoDetails": { "type": "string" },
        "siteId": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["id", "machineCode", "lotoLocked", "siteId"]
    },
    "demandeIntervention": {
      "title": "DemandeIntervention",
      "description": "Demande d'Intervention (DI) émise par l'exploitation ou production",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "machineCode": { "type": "string" },
        "siteId": { "type": "string" },
        "zone": { "type": "string" },
        "symptom": { "type": "string" },
        "severity": { "type": "string" },
        "urgency": { "type": "string" },
        "createdAt": { "type": "string" },
        "createdBy": { "type": "string" },
        "createdByRole": { "type": "string" },
        "status": { "type": "string" },
        "convertedToOtId": { "type": "string" },
        "comment": { "type": "string" }
      },
      "required": ["id", "machineCode", "siteId", "symptom", "createdAt", "createdBy", "status"]
    },
    "rapportFinIntervention": {
      "title": "RapportFinIntervention",
      "description": "Rapport de Fin d'Intervention (RFI) obligatoire avant clôture OT",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "workOrderId": { "type": "string" },
        "machineCode": { "type": "string" },
        "rootCause": { "type": "string" },
        "subSystem": { "type": "string" },
        "component": { "type": "string" },
        "remedyAction": { "type": "string" },
        "replacedParts": { "type": "array" },
        "durationRealHours": { "type": "number" },
        "techValidation": { "type": "boolean" },
        "supervisorValidation": { "type": "boolean" },
        "createdAt": { "type": "string" },
        "signedBy": { "type": "string" },
        "siteId": { "type": "string" }
      },
      "required": ["id", "workOrderId", "machineCode", "rootCause", "remedyAction", "durationRealHours", "siteId"]
    },
    "maintenanceTask": {
      "title": "MaintenanceTask",
      "description": "Fiche d'intervention ou tâche de maintenance préventive/corrective/quotidienne",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "enum": ["PREVENTIF", "CORRECTIF", "QUOTIDIEN"] },
        "label": { "type": "string" },
        "enginId": { "type": "string" },
        "enginModele": { "type": "string" },
        "mecanicienId": { "type": "string" },
        "mecanicienNom": { "type": "string" },
        "poste": { "enum": ["Poste 1", "Poste 2", "Poste 3"] },
        "siteId": { "type": "string" },
        "datePlanifiee": { "type": "string" },
        "dureeEstimee": { "enum": ["15min", "30min", "1h", "2h", "4h", "6h", "1j"] },
        "priorite": { "enum": ["CRITIQUE", "HAUTE", "NORMALE", "BASSE", "QUOTIDIENNE"] },
        "statut": { "enum": ["FAIT", "EN_COURS", "NON_FAIT", "REPORTE", "VALIDE"] },
        "commentaire": { "type": "string" },
        "photo": { "type": "string" },
        "motifReport": { "type": "string" },
        "echeanceHeures": { "type": "number" },
        "heuresEnginAuMoment": { "type": "number" },
        "generatedAt": { "type": "string" },
        "generationType": { "enum": ["AUTO_QUOTIDIEN", "AUTO_PM", "MANUEL"] },
        "deleted": { "type": "boolean" }
      },
      "required": ["id", "type", "label", "enginId", "enginModele", "siteId", "datePlanifiee", "priorite", "statut", "deleted"]
    },
    "checklist": {
      "title": "Checklist",
      "description": "Fiche d'inspection ou checklist enregistrée pour un engin",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "enum": ["CONDUCTEUR", "MAINTENANCE", "SECURITE"] },
        "date": { "type": "string" },
        "heure": { "type": "string" },
        "enginId": { "type": "string" },
        "enginModele": { "type": "string" },
        "signataire": { "type": "string" },
        "signataireId": { "type": "string" },
        "poste": { "enum": ["Poste 1", "Poste 2", "Poste 3"] },
        "siteId": { "type": "string" },
        "items": { "type": "object" },
        "commentaires": { "type": "object" },
        "timestamp": { "type": "number" },
        "deleted": { "type": "boolean" },
        "createdAt": { "type": "object" }
      },
      "required": ["id", "type", "date", "heure", "enginId", "enginModele", "signataire", "poste", "siteId", "items", "commentaires", "timestamp", "deleted"]
    },
    "systematicTaskConfig": {
      "title": "SystematicTaskConfig",
      "description": "Configuration des tâches systématiques imposées par site et par poste",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "siteId": { "type": "string" },
        "poste": { "type": "string" },
        "tasks": { "type": "array" },
        "updatedBy": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["id", "siteId", "poste", "tasks"]
    },
    "systematicTask": {
      "title": "SystematicTask",
      "description": "Fiche journalière de la tournée des tâches systématiques imposées à un mécanicien",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string" },
        "mecanicienId": { "type": "string" },
        "mecanicienNom": { "type": "string" },
        "siteId": { "type": "string" },
        "poste": { "type": "string" },
        "tasks": { "type": "array" },
        "status": { "enum": ["NON_FAIT", "PARTIEL", "COMPLET", "VALIDÉ"] },
        "alertSent": { "type": "boolean" },
        "alertSentAt": { "type": "string" },
        "photo": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["id", "date", "mecanicienId", "mecanicienNom", "siteId", "poste", "tasks", "status"]
    },
    "mecanicien": {
      "title": "Mecanicien",
      "description": "Fiche mécanicien et statistiques de performance (Mock S4, intégration S6)",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "matricule": { "type": "string" },
        "nom": { "type": "string" },
        "prenom": { "type": "string" },
        "photo": { "type": "string" },
        "siteId": { "type": "string" },
        "poste": { "type": "string" },
        "competences": { "type": "array" },
        "visaLOTO": { "type": "boolean" },
        "visaHauteur": { "type": "boolean" },
        "visaConfine": { "type": "boolean" },
        "telephone": { "type": "string" },
        "email": { "type": "string" },
        "stats": { "type": "object" },
        "active": { "type": "boolean" },
        "dateEmbauche": { "type": "string" },
        "source": { "type": "string" }
      },
      "required": ["uid", "matricule", "nom", "prenom", "siteId", "active"]
    },
    "pneumatique": {
      "title": "Pneumatique",
      "description": "Changement de pneumatique et suivi d'usure",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "enginId": { "type": "string" },
        "enginModele": { "type": "string" },
        "siteId": { "type": "string" },
        "position": { "type": "string" },
        "marque": { "type": "string" },
        "dimension": { "type": "string" },
        "type": { "type": "string" },
        "numeroSerie": { "type": "string" },
        "datePose": { "type": "string" },
        "heurePose": { "type": "number" },
        "ancienPneuDureeHeures": { "type": "number" },
        "ancienPneuRaison": { "type": "string" },
        "cout": { "type": "number" },
        "fournisseur": { "type": "string" },
        "changePar": { "type": "string" },
        "validePar": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "enginId", "siteId", "position", "marque", "cout", "changePar", "createdAt"]
    },
    "carnetSante": {
      "title": "CarnetSante",
      "description": "Fiche de santé d'un engin ou équipement de la flotte",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "enginId": { "type": "string" },
        "siteId": { "type": "string" },
        "healthScore": { "type": "number" },
        "lastChecked": { "type": "string" },
        "notes": { "type": "string" }
      },
      "required": ["id", "enginId", "siteId", "healthScore"]
    },
    "rootCauseAnalysis": {
      "title": "RootCauseAnalysis",
      "description": "Analyse de causes racines (RCA) d'une panne ou défaillance",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "workOrderId": { "type": "string" },
        "machineCode": { "type": "string" },
        "title": { "type": "string" },
        "status": { "enum": ["BROUILLON", "COMPLÉTÉ", "APPROUVÉ"] },
        "team": { "type": "array" },
        "problemDescription": { "type": "string" },
        "fiveWhys": { "type": "array" },
        "rootCause": { "type": "string" },
        "preventiveActions": { "type": "array" },
        "siteId": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" },
        "aiAnalysis": { "type": "string" }
      },
      "required": ["id", "workOrderId", "machineCode", "title", "status", "siteId"]
    }
  },
  "firestore": {
    "mecaniciens": {
      "schema": "mecanicien",
      "description": "Collection des mécaniciens et statistiques"
    },
    "pneumatiques": {
      "schema": "pneumatique",
      "description": "Collection des changements et suivi des pneumatiques"
    },
    "systematicTaskConfigs": {
      "schema": "systematicTaskConfig",
      "description": "Collection de configuration des tâches systématiques"
    },
    "systematicTasks": {
      "schema": "systematicTask",
      "description": "Collection des tournées de tâches systématiques journalières des mécaniciens"
    },
    "users": {
      "schema": "user",
      "description": "Collection des profils de maintenance et d'administration"
    },
    "sites": {
      "schema": "site",
      "description": "Collection des sites miniers"
    },
    "engins": {
      "schema": "engin",
      "description": "Collection des engins de la flotte"
    },
    "pannes": {
      "schema": "panne",
      "description": "Collection des pannes signalées"
    },
    "pieces": {
      "schema": "piece",
      "description": "Collection du stock de pièces"
    },
    "lotoLocks": {
      "schema": "lotoLock",
      "description": "Collection de verrouillage/consignation LOTO globale des machines"
    },
    "demandesIntervention": {
      "schema": "demandeIntervention",
      "description": "Collection des Demandes d'Intervention (DI) GMAO"
    },
    "rapportsFinIntervention": {
      "schema": "rapportFinIntervention",
      "description": "Collection des Rapports de Fin d'Intervention (RFI) GMAO"
    },
    "maintenanceTasks": {
      "schema": "maintenanceTask",
      "description": "Collection centrale des fiches de maintenance, de correctifs et de rondes de graissage"
    },
    "checklists": {
      "schema": "checklist",
      "description": "Collection des checklists et inspections de sécurité/conducteur/maintenance"
    },
    "carnetSante": {
      "schema": "carnetSante",
      "description": "Collection des fiches de santé d'engins"
    },
    "rootCauseAnalysis": {
      "schema": "rootCauseAnalysis",
      "description": "Collection des analyses de causes racines (RCA) de pannes"
    },
    "config": {
      "schema": "object",
      "description": "Collection de configuration globale du système"
    },
    "config/imports/history": {
      "schema": "object",
      "description": "Sous-collection de traçabilité des exécutions d'import de données externes"
    }
  }
}
