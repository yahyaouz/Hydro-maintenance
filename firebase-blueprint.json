      "description": "Collection des Rapports de Fin d'Intervention (RFI) GMAO"
    },
    "maintenanceTasks": {
      "schema": "maintenanceTask",
      "description": "Collection centrale des fiches de maintenance, de correctifs et de rondes de graissage"
    },
    "checklists": {
