    },
    "intervention": {
      "title": "Intervention",
      "description": "Rapport d'intervention réelle de production",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "mecanicienMatricule": { "type": "string" },
        "mecanicienNom": { "type": "string" },
        "date": { "type": "string" },
        "enginMatricule": { "type": "string" },
        "typeIntervention": { "type": "string" },
        "heureDebutReelle": { "type": "string" },
        "heureFinReelle": { "type": "string" },
        "dureeHeures": { "type": "number" },
        "descriptionTravaux": { "type": "string" },
        "status": { "type": "string" },
        "piecesUtilisees": { "type": "array" },
        "siteId": { "type": "string" },
        "importedAt": { "type": "string" }
      },
      "required": ["id", "mecanicienMatricule", "date", "enginMatricule", "dureeHeures"]
    },
    "annotationEvenement": {
      "title": "AnnotationEvenement",
      "description": "Annotation d'événement de maintenance pour expliquer un pic ou une chute sur la courbe",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "siteId": { "type": "string" },
        "moisConcerne": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}$" },
        "type": { "enum": ["GREVE", "PANNE_ELECTRIQUE_GENERALE", "CHANGEMENT_EQUIPE", "AUTRE"] },
        "texte": { "type": "string" },
        "auteurId": { "type": "string" },
        "auteurNom": { "type": "string" },
        "createdAt": { "type": "object" }
      },
      "required": ["siteId", "moisConcerne", "type", "texte", "auteurId", "auteurNom"]
    },
    "objectifSite": {
      "title": "ObjectifSite",
      "description": "Objectifs de performance définis pour un site ou objectif global de la direction",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "dispoTarget": { "type": "number" },
