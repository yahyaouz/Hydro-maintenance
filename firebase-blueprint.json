{
  "entities": {
    "site": {
      "title": "Site",
      "description": "Un site minier",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "nom": { "type": "string" },
        "code": { "type": "string" }
      },
      "required": ["id", "nom", "code"]
    },
    "engin": {
      "title": "Engin",
      "description": "Un engin de la flotte",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "id_parc": { "type": "string" },
        "modele": { "type": "string" },
        "site": { "type": "string" },
        "status": { "enum": ["EN SERVICE", "PANNE", "MAINTENANCE", "ARRÊT"] },
        "compteur": { "type": "number" },
        "sante": { "type": "number" },
        "disponibilite": { "type": "number" }
      },
      "required": ["id", "id_parc", "modele", "site", "status", "compteur"]
    },
    "panne": {
      "title": "Panne",
      "description": "Signalement d'une panne",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "enginId": { "type": "string" },
        "titre": { "type": "string" },
        "priorite": { "enum": ["CRITIQUE", "ÉLEVÉ", "MOYEN", "BAS"] },
        "status": { "enum": ["OUVERT", "EN COURS", "RÉSOLU"] },
        "site": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "description": { "type": "string" }
      },
      "required": ["id", "enginId", "titre", "priorite", "status", "site", "date"]
    },
    "piece": {
      "title": "Pièce",
      "description": "Pièce détachée en stock",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "ref": { "type": "string" },
        "nom": { "type": "string" },
        "categorie": { "type": "string" },
        "stock": { "type": "number" },
        "min": { "type": "number" },
        "prix": { "type": "number" },
        "siteId": { "type": "string" }
      },
      "required": ["id", "ref", "nom", "stock", "min", "prix", "siteId"]
    },
    "user": {
      "title": "User",
      "description": "Profil utilisateur du système SOU-GMAO",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string" },
        "siteId": { "type": "string" },
        "active": { "type": "boolean" },
        "createdAt": { "type": "string" },
        "lastLogin": { "type": "string" },
        "authProvider": { "type": "string" }
      },
      "required": ["uid", "displayName", "email", "role", "siteId", "active", "authProvider"]
    },
    "lotoLock": {
      "title": "LotoLock",
      "description": "État de consignation LOTO d'un engin ou machine de la flotte",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "machineCode": { "type": "string" },
        "lotoLocked": { "type": "boolean" },
        "lotoOwner": { "type": "string" },
        "lotoStartedAt": { "type": "string" },
        "lotoReleasedAt": { "type": "string" },
        "lotoWorkOrderId": { "type": "string" },
        "lotoSupervisorValidation": { "type": "boolean" },
        "lotoDetails": { "type": "string" },
        "siteId": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["id", "machineCode", "lotoLocked", "siteId"]
    },
    "demandeIntervention": {
      "title": "DemandeIntervention",
      "description": "Demande d'Intervention (DI) émise par l'exploitation ou production",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "machineCode": { "type": "string" },
        "siteId": { "type": "string" },
        "zone": { "type": "string" },
        "symptom": { "type": "string" },
        "severity": { "type": "string" },
        "urgency": { "type": "string" },
        "createdAt": { "type": "string" },
        "createdBy": { "type": "string" },
        "createdByRole": { "type": "string" },
        "status": { "type": "string" },
        "convertedToOtId": { "type": "string" },
        "comment": { "type": "string" }
      },
      "required": ["id", "machineCode", "siteId", "symptom", "createdAt", "createdBy", "status"]
    },
    "rapportFinIntervention": {
      "title": "RapportFinIntervention",
      "description": "Rapport de Fin d'Intervention (RFI) obligatoire avant clôture OT",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "workOrderId": { "type": "string" },
        "machineCode": { "type": "string" },
        "rootCause": { "type": "string" },
        "subSystem": { "type": "string" },
        "component": { "type": "string" },
        "remedyAction": { "type": "string" },
        "replacedParts": { "type": "array" },
        "durationRealHours": { "type": "number" },
        "techValidation": { "type": "boolean" },
        "supervisorValidation": { "type": "boolean" },
        "createdAt": { "type": "string" },
        "signedBy": { "type": "string" },
        "siteId": { "type": "string" }
      },
      "required": ["id", "workOrderId", "machineCode", "rootCause", "remedyAction", "durationRealHours", "siteId"]
    },
    "maintenanceTask": {
      "title": "MaintenanceTask",
      "description": "Fiche d'intervention ou tâche de maintenance préventive/corrective/quotidienne",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "enum": ["PREVENTIF", "CORRECTIF", "QUOTIDIEN"] },
        "label": { "type": "string" },
        "enginId": { "type": "string" },
        "enginModele": { "type": "string" },
        "mecanicienId": { "type": "string" },
        "mecanicienNom": { "type": "string" },
        "poste": { "enum": ["Poste 1", "Poste 2", "Poste 3"] },
        "siteId": { "type": "string" },
        "datePlanifiee": { "type": "string" },
        "dureeEstimee": { "enum": ["15min", "30min", "1h", "2h", "4h", "6h", "1j"] },
        "priorite": { "enum": ["CRITIQUE", "HAUTE", "NORMALE", "BASSE", "QUOTIDIENNE"] },
        "statut": { "enum": ["FAIT", "EN_COURS", "NON_FAIT", "REPORTE", "VALIDE"] },
        "commentaire": { "type": "string" },
        "photo": { "type": "string" },
        "motifReport": { "type": "string" },
        "echeanceHeures": { "type": "number" },
        "heuresEnginAuMoment": { "type": "number" },
        "generatedAt": { "type": "string" },
        "generationType": { "enum": ["AUTO_QUOTIDIEN", "AUTO_PM", "MANUEL"] },
        "deleted": { "type": "boolean" }
      },
      "required": ["id", "type", "label", "enginId", "enginModele", "siteId", "datePlanifiee", "priorite", "statut", "deleted"]
    },
    "checklist": {
      "title": "Checklist",
      "description": "Fiche d'inspection ou checklist enregistrée pour un engin",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "enum": ["CONDUCTEUR", "MAINTENANCE", "SECURITE"] },
        "date": { "type": "string" },
        "heure": { "type": "string" },
        "enginId": { "type": "string" },
        "enginModele": { "type": "string" },
        "signataire": { "type": "string" },
        "signataireId": { "type": "string" },
        "poste": { "enum": ["Poste 1", "Poste 2", "Poste 3"] },
        "siteId": { "type": "string" },
        "items": { "type": "object" },
        "commentaires": { "type": "object" },
        "timestamp": { "type": "number" },
        "deleted": { "type": "boolean" },
        "createdAt": { "type": "object" }
      },
      "required": ["id", "type", "date", "heure", "enginId", "enginModele", "signataire", "poste", "siteId", "items", "commentaires", "timestamp", "deleted"]
    },
    "systematicTaskConfig": {
      "title": "SystematicTaskConfig",
      "description": "Configuration des tâches systématiques imposées par site et par poste",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "siteId": { "type": "string" },
        "poste": { "type": "string" },
        "tasks": { "type": "array" },
        "updatedBy": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["id", "siteId", "poste", "tasks"]
    },
    "systematicTask": {
      "title": "SystematicTask",
      "description": "Fiche journalière de la tournée des tâches systématiques imposées à un mécanicien",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string" },
        "mecanicienId": { "type": "string" },
        "mecanicienNom": { "type": "string" },
        "siteId": { "type": "string" },
        "poste": { "type": "string" },
        "tasks": { "type": "array" },
        "status": { "enum": ["NON_FAIT", "PARTIEL", "COMPLET", "VALIDÉ"] },
        "alertSent": { "type": "boolean" },
        "alertSentAt": { "type": "string" },
        "photo": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["id", "date", "mecanicienId", "mecanicienNom", "siteId", "poste", "tasks", "status"]
    },
    "mecanicien": {
      "title": "Mecanicien",
      "description": "Fiche mécanicien et statistiques de performance (Mock S4, intégration S6). ARCHITECTURE DUALE: Collection 'users' pour comptes de connexion GMAO (auth Firebase), Collection 'mecaniciens' pour le référentiel opérationnel des techniciens. Certains mécaniciens n'ont pas de compte GMAO (travaillent hors-ligne). Quand un mécano a un compte, userUid fait le lien entre les deux. L'import Planification (SPRINT 6) écrit dans 'mecaniciens'. Le module Mécaniciens (SPRINT 4) lit depuis 'mecaniciens'.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "userUid": { "type": "string" },
        "matricule": { "type": "string" },
        "nom": { "type": "string" },
        "prenom": { "type": "string" },
        "photo": { "type": "string", "description": "URL Firebase Storage : /mecaniciens/{matricule}/avatar.jpg ou base64. Upload via le formulaire admin, PAS de mock externe" },
        "siteId": { "type": "string" },
        "poste": { "type": "string" },
        "equipe": { "type": "string" },
        "competences": { "type": "array" },
        "telephone": { "type": "string" },
        "telephoneUrgence": { "type": "string" },
        "email": { "type": "string" },
        "adresse": { "type": "string" },
        "dateNaissance": { "type": "string" },
        "dateEmbauche": { "type": "string" },
        "visas": {
          "type": "object",
          "properties": {
            "LOTO": {
              "type": "object",
              "properties": {
                "active": { "type": "boolean" },
                "dateExpiration": { "type": "string" }
              }
            },
            "HAUTEUR": {
              "type": "object",
              "properties": {
                "active": { "type": "boolean" },
                "dateExpiration": { "type": "string" }
              }
            },
            "CONFINE": {
              "type": "object",
              "properties": {
                "active": { "type": "boolean" },
                "dateExpiration": { "type": "string" }
              }
            },
            "ELECTRIQUE_HV": {
              "type": "object",
              "properties": {
                "active": { "type": "boolean" },
                "dateExpiration": { "type": "string" }
              }
            },
            "CHARGEUR": {
              "type": "object",
              "properties": {
                "active": { "type": "boolean" },
                "dateExpiration": { "type": "string" }
              }
            }
          }
        },
        "documents": {
          "type": "object",
          "properties": {
            "contrat": { "type": "string" },
            "diplome": { "type": "string" },
            "visaMedical": { "type": "string" },
            "attestationFormation": { "type": "string" },
            "caces": { "type": "string" }
          }
        },
        "stats": {
          "type": "object",
          "properties": {
            "totalInterventions": { "type": "number" },
            "interventionsCeMois": { "type": "number" },
            "derniereIntervention": { "type": "string" },
            "scoreMensuel": { "type": "number" },
            "mttrMoyen": { "type": "number" },
            "tauxResolutionPremiereFois": { "type": "number" },
            "tauxTournéesCompletes": { "type": "number" },
            "heuresInterventionCeMois": { "type": "number" }
          }
        },
        "active": { "type": "boolean" },
        "source": { "type": "string" }
      },
      "required": ["uid", "matricule", "nom", "prenom", "siteId", "active"]
    },
    "pneumatique": {
      "title": "Pneumatique",
      "description": "Changement de pneumatique et suivi d'usure",
