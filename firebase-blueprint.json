        "lastChecked": { "type": "string" },
        "notes": { "type": "string" }
      },
      "required": ["id", "enginId", "siteId", "healthScore"]
    },
    "rootCauseAnalysis": {
      "title": "RootCauseAnalysis",
      "description": "Analyse de causes racines (RCA) d'une panne ou défaillance",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "workOrderId": { "type": "string" },
        "machineCode": { "type": "string" },
        "title": { "type": "string" },
        "status": { "enum": ["BROUILLON", "COMPLÉTÉ", "APPROUVÉ"] },
        "team": { "type": "array" },
        "problemDescription": { "type": "string" },
        "fiveWhys": { "type": "array" },
        "rootCause": { "type": "string" },
        "preventiveActions": { "type": "array" },
        "siteId": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" },
        "aiAnalysis": { "type": "string" }
      },
      "required": ["id", "workOrderId", "machineCode", "title", "status", "siteId"]
    },
    "consommation": {
      "title": "Consommation",
