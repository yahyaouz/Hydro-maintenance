rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /mecaniciens/{matricule}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /systematicTasks/{sheetId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
