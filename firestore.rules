rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default system lock
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    // Retreives the user record to evaluate site segment and role permissions
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isRole(role) {
      return isSignedIn() && (
        getUserData().role == role || 
        getUserData().role == 'ADMIN'
      );
    }

    // Multi-site isolation: ensures users can only read/write documents linked to their active site or site 'TOUS'
    function matchesSite(siteId) {
      return isSignedIn() && (
        getUserData().siteId == 'TOUS' || 
        getUserData().siteId == siteId || 
        getUserData().role == 'ADMIN'
      );
    }

    match /users/{userId} {
      // Allow viewers and registered agents to read the profiles directory
      allow read: if true;
      allow create: if isSignedIn() && request.auth.uid == userId && (
        !request.resource.data.keys().hasAny(['role']) || 
        request.resource.data.role == 'VIEWER'
      );
      allow update: if isSignedIn() && (
        getUserData().role == 'ADMIN' || (
          request.auth.uid == userId && 
          request.resource.data.role == resource.data.role
        )
      );
      allow delete: if isSignedIn() && getUserData().role == 'ADMIN';
    }

    match /sites/{siteId} {
      allow read: if true;
      allow write: if isSignedIn() && getUserData().role == 'ADMIN';
    }

    match /engins/{enginId} {
      allow read: if true;
      // Protect against dirty overwriting during simultaneous offline updates
      allow write: if isSignedIn() && matchesSite(request.resource.data.siteId || 'SMI') && (
        !exists(/databases/$(database)/documents/engins/$(enginId)) || 
        request.resource.data.updatedAt >= resource.data.updatedAt || 
        isRole('ADMIN')
      );
    }

    match /workorders/{orderId} {
      allow read: if true;
      // Standard rules for technicians to change state and admin to create
      allow write: if isSignedIn() && matchesSite(request.resource.data.siteId || 'SMI') && (
        isRole('CHEF_QUART') || isRole('MECANICIEN') || isRole('ADMIN')
      );
    }

    match /pannes/{panneId} {
      allow read: if true;
      allow write: if isSignedIn() && matchesSite(request.resource.data.siteId || 'SMI') && (
        isRole('CHEF_QUART') || isRole('OPERATEUR') || isRole('MECANICIEN')
      );
    }

    match /pieces/{pieceId} {
      allow read: if true;
      allow write: if isSignedIn() && matchesSite(request.resource.data.siteId || 'SMI') && isRole('CHEF_QUART');
    }

    match /feedbacks/{feedbackId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && isRole('ADMIN');
    }

    // Security surveillance for VIEWER telemetries
    match /viewerAuditLogs/{logId} {
      // Viewers and system are permitted to dispatch audit logs
      allow create: if true;
      // Only validated Administrators can read audit tracking telemetry
      allow read: if isSignedIn() && getUserData().role == 'ADMIN';
      // Logs are unmutable and cannot be tempered with or erased
      allow update, delete: if false;
    }

    // Consolidated viewer session summaries (zero data leak - only ADMIN can read)
    match /viewerSessions/{sessionId} {
      allow create, update: if true;
      allow read: if isSignedIn() && getUserData().role == 'ADMIN';
      allow delete: if false;
    }

    // Critical security event logs
    match /viewerSecurityEvents/{eventId} {
      allow create, update: if true;
      allow read: if isSignedIn() && getUserData().role == 'ADMIN';
      allow delete: if false;
    }

    // Daily operational analytics metrics
    match /viewerAnalyticsDaily/{dayId} {
      allow create, update: if true;
      allow read: if isSignedIn() && getUserData().role == 'ADMIN';
      allow delete: if false;
    }
  }
}
