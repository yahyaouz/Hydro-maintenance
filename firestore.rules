rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default system lock
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    // Retreives the user record to evaluate site segment and role permissions
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isRole(role) {
      return isSignedIn() && (
        getUserData().role == role || 
        getUserData().role == 'ADMIN'
      );
    }

    // Multi-site isolation: ensures users can only read/write documents linked to their active site or site 'TOUS'
    function matchesSite(siteId) {
      return isSignedIn() && (
        getUserData().siteId == 'TOUS' || 
        getUserData().siteId == siteId || 
        getUserData().role == 'ADMIN'
      );
    }

    // Server-Side HSE Validation: Checks if the machine has an active LOTO lock in database
    function isMachineLotoLocked(machineCode) {
      return exists(/databases/$(database)/documents/lotoLocks/$(machineCode)) && 
             get(/databases/$(database)/documents/lotoLocks/$(machineCode)).data.lotoLocked == true;
    }

    match /users/{userId} {
      // Allow viewers and registered agents to read the profiles directory
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId && 
        request.resource.data.active == false;
      allow update: if isSignedIn() && (
        getUserData().role == 'ADMIN' || (
          request.auth.uid == userId && 
          request.resource.data.role == resource.data.role &&
          request.resource.data.get('requestedRole', '') == resource.data.get('requestedRole', '')
        )
      );
      allow delete: if isSignedIn() && getUserData().role == 'ADMIN';
    }

    match /engins/{enginId} {
      allow read: if isSignedIn();
      // Protect against dirty overwriting and enforce global LOTO lock rules on server-side
      allow write: if isSignedIn() && matchesSite(request.resource.data.siteId || 'SMI') && (
        (!isMachineLotoLocked(enginId) && (
          !exists(/databases/$(database)/documents/engins/$(enginId)) || 
          request.resource.data.updatedAt >= resource.data.updatedAt
        )) || 
        isRole('ADMIN')
      );
    }

    match /workorders/{orderId} {
      allow read: if isSignedIn();
      // Prevent creating workorders for locked machines unless admin override
      allow create: if isSignedIn() && matchesSite(request.resource.data.siteId || 'SMI') && (
        !isMachineLotoLocked(request.resource.data.machineCode) || isRole('ADMIN')
      );
      // Validate that only the workorder responsible for LOTO lock or non-locked ones can be modified
      allow update: if isSignedIn() && matchesSite(request.resource.data.siteId || 'SMI') && (
        (isRole('CHEF_QUART') || isRole('MECANICIEN') || isRole('ADMIN')) && (
          !isMachineLotoLocked(resource.data.machineCode) || 
          orderId == get(/databases/$(database)/documents/lotoLocks/$(resource.data.machineCode)).data.lotoWorkOrderId ||
          isRole('ADMIN')
        )
      );
      allow delete: if isSignedIn() && isRole('ADMIN');
    }

    match /lotoLocks/{lockId} {
      allow read: if isSignedIn();
      // Authorized maintenance crews can engage, approve or release LOTO locks
      allow write: if isSignedIn() && matchesSite(request.resource.data.siteId || 'SMI') && (
        isRole('MECANICIEN') || isRole('ADMIN')
      );
    }

    match /pannes/{panneId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && matchesSite(request.resource.data.siteId || 'SMI');
    }

    match /pieces/{pieceId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && matchesSite(request.resource.data.siteId || 'SMI') && (
        isRole('CHEF_QUART') || 
        getUserData().role == 'RESPONSABLE_MAINTENANCE'
      );
    }

    match /maintenances/{maintenanceId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && matchesSite(request.resource.data.siteId || 'SMI') && (
        isRole('MECANICIEN') || isRole('CHEF_QUART') || isRole('ADMIN')
      );
    }

    match /mecaniciens/{mecaId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (
        getUserData().role == 'ADMIN' ||
        getUserData().role == 'RESPONSABLE_MAINTENANCE'
      );
    }

    match /chantiers/{chantierId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && getUserData().role == 'ADMIN';
    }

    match /pmIntervalles/{intervalleId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (
        getUserData().role == 'ADMIN' ||
        getUserData().role == 'RESPONSABLE_MAINTENANCE'
      );
    }

    match /pneus/{pneuId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && matchesSite(request.resource.data.siteId || 'SMI') && (
        isRole('MECANICIEN') || isRole('CHEF_QUART') || isRole('ADMIN')
      );
    }

    match /pneumatiques/{pneuId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && matchesSite(request.resource.data.siteId || 'SMI') && (
        isRole('MECANICIEN') || isRole('CHEF_QUART') || isRole('ADMIN')
      );
    }

    match /auditLogs/{logId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && isRole('ADMIN');
    }

    match /rapportsFinIntervention/{rfiId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && matchesSite(request.resource.data.siteId || 'SMI') && (
        isRole('MECANICIEN') || isRole('CHEF_QUART') || isRole('ADMIN')
      );
    }

    match /feedbacks/{feedbackId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && isRole('ADMIN');
    }

    match /maintenanceTasks/{taskId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && matchesSite(request.resource.data.siteId || 'SMI');
      allow update: if isSignedIn() && matchesSite(resource.data.siteId || 'SMI') && (
        isRole('MECANICIEN') || isRole('RESPONSABLE_MAINTENANCE') || isRole('ADMIN')
      );
      allow delete: if isSignedIn() && isRole('ADMIN');
    }

    match /checklists/{checklistId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && matchesSite(request.resource.data.siteId || 'SMI');
      allow update: if isSignedIn() && (
        isRole('ADMIN') || isRole('RESPONSABLE_MAINTENANCE') ||
        (resource.data.signataireId == request.auth.uid)
      );
      allow delete: if isSignedIn() && isRole('ADMIN');
    }

    match /systematicTaskConfigs/{configId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (
        getUserData().role == 'ADMIN' ||
        getUserData().role == 'RESPONSABLE_MAINTENANCE'
      );
    }

    match /systematicTasks/{taskId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && matchesSite(request.resource.data.siteId || 'SMI');
      allow update: if isSignedIn() && matchesSite(resource.data.siteId || 'SMI');
      allow delete: if isSignedIn() && isRole('ADMIN');
    }

    match /alerts/{alertId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /carnetSante/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && matchesSite(request.resource.data.siteId || 'SMI');
    }

    match /rootCauseAnalysis/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && matchesSite(request.resource.data.siteId || 'SMI');
    }

    match /consommations/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && matchesSite(request.resource.data.site || 'SMI') && (
        getUserData().role == 'ADMIN' ||
        getUserData().role == 'RESPONSABLE_MAINTENANCE'
      );
    }

    match /carburants/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && matchesSite(request.resource.data.site || 'SMI') && (
        getUserData().role == 'ADMIN' ||
        getUserData().role == 'RESPONSABLE_MAINTENANCE'
      );
    }

    match /interventions/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && matchesSite(request.resource.data.siteId || 'SMI') && (
        getUserData().role == 'ADMIN' ||
        getUserData().role == 'RESPONSABLE_MAINTENANCE'
      );
    }

    match /config/{configId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (
        getUserData().role == 'ADMIN' ||
        getUserData().role == 'RESPONSABLE_MAINTENANCE'
      );

      match /history/{logId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && (
          getUserData().role == 'ADMIN' ||
          getUserData().role == 'RESPONSABLE_MAINTENANCE'
        );
        allow update, delete: if isSignedIn() && isRole('ADMIN');
      }
    }

    match /annotationsEvenements/{annotationId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.auteurId == request.auth.uid;
      allow update, delete: if isSignedIn() && (
        resource.data.auteurId == request.auth.uid || isRole('ADMIN')
      );
    }

    match /objectifsSites/{siteId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (isRole('ADMIN') || isRole('DIRECTION'));
    }

    match /systemLogs/{logId} {
      allow read: if isSignedIn() && isRole('ADMIN');
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    match /notifications/{notifId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn() && isRole('ADMIN');
    }
  }
}
